page {
  --ink: #11110f;
  --muted: #74736d;
  --paper: #fbfaf6;
  --ground: #f1efe8;
  --line: #dedbd1;
  --lime: #dceeb1;
  --lilac: #cab9ef;
  --cream: #f1e7c9;
  --pink: #efd2d2;
  --mint: #c8e4cf;
  --coral: #efc8b5;
  background: var(--ground);
  color: var(--ink);
  font-family: "PingFang SC", "Noto Sans CJK SC", sans-serif;
  font-size: 30rpx;
}

view, text, button, input, textarea, scroll-view { box-sizing: border-box; }
button::after { border: 0; }
button { margin: 0; }
.page { min-height: 100vh; padding: 36rpx 28rpx 64rpx; }
.eyebrow { color: var(--muted); font-size: 21rpx; font-weight: 650; letter-spacing: 3rpx; text-transform: uppercase; }
.display { margin: 14rpx 0; font-family: "STKaiti", "KaiTi", serif; font-size: 70rpx; font-weight: 400; line-height: 1.08; letter-spacing: 2rpx; }
.h1 { margin: 12rpx 0; font-family: "STKaiti", "KaiTi", serif; font-size: 52rpx; font-weight: 400; line-height: 1.2; }
.h2 { margin: 0; font-size: 34rpx; font-weight: 650; line-height: 1.35; }
.body { color: #33332f; font-size: 29rpx; line-height: 1.8; }
.muted { color: var(--muted); }
.small { font-size: 24rpx; line-height: 1.6; }
.card { margin-top: 24rpx; padding: 32rpx; border-radius: 28rpx; background: var(--paper); }
.card-lime { background: var(--lime); }
.card-lilac { background: var(--lilac); }
.card-cream { background: var(--cream); }
.card-pink { background: var(--pink); }
.card-mint { background: var(--mint); }
.row { display: flex; align-items: center; }
.between { display: flex; align-items: center; justify-content: space-between; gap: 20rpx; }
.pill { min-height: 84rpx; padding: 0 32rpx; border-radius: 999rpx; background: var(--ink); color: #fff; font-size: 27rpx; font-weight: 600; line-height: 84rpx; text-align: center; }
.pill-light { background: var(--paper); color: var(--ink); }
.pill-outline { border: 2rpx solid var(--ink); background: transparent; color: var(--ink); }
.pill-small { min-height: 64rpx; padding: 0 24rpx; font-size: 24rpx; line-height: 64rpx; }
.link-row { min-height: 92rpx; border-bottom: 1rpx solid var(--line); display: flex; align-items: center; justify-content: space-between; gap: 20rpx; }
.link-row:last-child { border-bottom: 0; }
.arrow { font-size: 32rpx; }
.tag { display: inline-flex; align-items: center; min-height: 48rpx; padding: 0 18rpx; border: 1rpx solid rgba(17,17,15,.35); border-radius: 999rpx; font-size: 22rpx; }
.progress { height: 8rpx; overflow: hidden; border-radius: 8rpx; background: rgba(17,17,15,.14); }
.progress > view { height: 100%; border-radius: inherit; background: var(--ink); }
.section-head { margin: 52rpx 4rpx 16rpx; }
.empty { padding: 80rpx 30rpx; text-align: center; }
.safe-bottom { height: env(safe-area-inset-bottom); }
.serif { font-family: "STKaiti", "KaiTi", serif; }
.input { min-height: 88rpx; padding: 20rpx 26rpx; border-radius: 22rpx; background: var(--paper); font-size: 28rpx; }
.textarea { width: 100%; min-height: 260rpx; padding: 24rpx; border-radius: 22rpx; background: #fff; font-size: 29rpx; line-height: 1.7; }
.divider { height: 1rpx; margin: 28rpx 0; background: rgba(17,17,15,.18); }
.toast-note { padding: 20rpx 24rpx; border-left: 6rpx solid var(--ink); background: #fff; color: #45443f; font-size: 24rpx; line-height: 1.6; }
