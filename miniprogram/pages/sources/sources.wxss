.display { white-space: pre-line; font-size: 62rpx; }
.status .h1 { margin: 26rpx 0; }
.meta { margin: 28rpx 0; display: grid; grid-template-columns: 150rpx 1fr; gap: 18rpx; font-size: 25rpx; line-height: 1.6; }.meta text:nth-child(odd) { color: var(--muted); }
.checks { padding-top: 8rpx; padding-bottom: 8rpx; }.checks view { min-height: 88rpx; border-bottom: 1rpx solid var(--line); display: flex; align-items: center; justify-content: space-between; }.checks view:last-child { border: 0; }.check-value { font-size: 34rpx; font-weight: 400; }
.checksum { padding: 30rpx 8rpx 60rpx; text-align: center; }
