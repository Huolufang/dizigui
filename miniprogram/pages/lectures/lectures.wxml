<view class="page">
  <view class="display">《细讲弟子规》讲稿学习</view>
  <view class="search-entry" bindtap="openSearch">⌕　在 40 讲正文中搜索</view>
  <view class="summary between"><text>{{readCount}} 讲已读</text><text>共 40 讲</text></view>
  <view class="lecture-list card">
    <view wx:for="{{lectures}}" wx:key="number" class="lecture-row" data-number="{{item.number}}" bindtap="openLecture">
      <view class="number">{{item.numberLabel}}</view>
      <view class="lecture-copy"><view class="h2">细讲弟子规 · 第{{item.number}}讲</view><text class="small muted">{{item.paragraphCount}} 段 · {{item.statusLabel}}</text></view>
      <text class="arrow">↗</text>
    </view>
  </view>
</view>
