<view class="page search-page">
  <text class="eyebrow">{{lectureFilter ? '当前讲次内查找' : '完全离线搜索'}}</text>
  <view class="display">找回一句话的\n出处。</view>
  <form bindsubmit="submit"><view class="search-box"><input value="{{query}}" placeholder="输入一个或多个关键词" confirm-type="search" bindinput="onInput" bindconfirm="submit"/><button form-type="submit">搜索</button></view></form>
  <view wx:if="{{!searched && recent.length}}" class="recent"><view class="between section-head"><text class="eyebrow">最近搜索</text><text class="small muted" bindtap="clearRecent">全部清除</text></view><view wx:for="{{recent}}" wx:key="*this" class="recent-row"><text data-term="{{item}}" bindtap="useRecent">{{item}}</text><text data-term="{{item}}" catchtap="deleteRecent">×</text></view></view>
  <view wx:if="{{searched && results}}">
    <view class="summary small muted">共 {{results.total}} 条结果 · 用时 {{results.elapsed}} ms。多个关键词时需全部命中。</view>
    <view wx:if="{{!results.total}}" class="empty card"><view class="h1">没有找到结果</view><view class="body muted">已搜索原文、课程标题和 40 讲正文。可以缩短关键词或减少关键词数量。</view></view>
    <block wx:if="{{results.originals.length}}"><view class="section-head"><text class="eyebrow">原文 · {{results.originals.length}}</text></view><view wx:for="{{visible.originals}}" wx:key="id" class="result card" data-type="original" data-course="{{item.courseId}}" data-unit="{{item.id}}" bindtap="openResult"><view class="h2">{{item.title}}</view><view class="snippet"><block wx:for="{{item.segments}}" wx:for-item="segment" wx:key="index"><text class="{{segment.hit ? 'hit' : ''}}">{{segment.text}}</text></block></view></view><button wx:if="{{results.originals.length > limits.originals}}" class="more" data-key="originals" bindtap="more">查看更多原文结果</button></block>
    <block wx:if="{{results.courses.length}}"><view class="section-head"><text class="eyebrow">课程 · {{results.courses.length}}</text></view><view wx:for="{{visible.courses}}" wx:key="id" class="result card" data-type="course" data-course="{{item.courseId}}" bindtap="openResult"><view class="h2">{{item.title}}</view><view class="snippet"><block wx:for="{{item.segments}}" wx:for-item="segment" wx:key="index"><text class="{{segment.hit ? 'hit' : ''}}">{{segment.text}}</text></block></view></view></block>
    <block wx:if="{{results.lectures.length}}"><view class="section-head"><text class="eyebrow">讲稿 · {{results.lectures.length}}</text></view><view wx:for="{{visible.lectures}}" wx:key="id" class="result card" data-type="lecture" data-lecture="{{item.lectureNumber}}" data-paragraph="{{item.paragraphIndex}}" bindtap="openResult"><view class="h2">{{item.title}}</view><view class="snippet"><block wx:for="{{item.segments}}" wx:for-item="segment" wx:key="index"><text class="{{segment.hit ? 'hit' : ''}}">{{segment.text}}</text></block></view></view><button wx:if="{{results.lectures.length > limits.lectures}}" class="more" data-key="lectures" bindtap="more">查看更多讲稿结果</button></block>
  </view>
</view>
